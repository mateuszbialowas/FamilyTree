{
  "expo": {
    "name": "Family Tree",
    "slug": "family-tree",
    "version": "1.0.0",
    "scheme": "family-tree",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF5E6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mateuszbialowas.FamilyTree",
      "buildNumber": "1.0.0"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "320000d9-99df-46e3-b7e0-a036a58e0d06"
      }
    },
    "owner": "mateuszbialowas"
  }
}
