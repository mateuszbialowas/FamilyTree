{
  "expo": {
    "name": "Family Tree",
    "slug": "family-tree",
    "version": "1.0.0",
    "scheme": "family-tree",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF5E6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mateuszbialowas.FamilyTree",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "owner": "mateuszbialowas",
    "extra": {
      "eas": {
        "projectId": "fa7d8a97-29fa-46f9-a3da-69a3549740d6"
      }
    }
  }
}
